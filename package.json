{
  "name": "goit-node-js",
  "version": "1.0.0",
  "description": "goit-node-js",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "get-all": "node src/scripts/getAllContacts",
    "generate": "node src/scripts/generateContacts.js",
    "add-one": "node src/scripts/addOneContact.js",
    "import-contacts": "node src/scripts/importContacts.js",
    "count": "node src/scripts/countContacts.js",
    "remove-last": "node src/scripts/removeLastContact.js",
    "remove-all": "node src/scripts/removeAllContacts.js",
    "build-docs": "npx @redocly/cli bundle docs/openapi.yaml -o docs/swagger.json",
    "build": "npm run build-docs",
    "preview-docs": "npx @redocly/cli build-docs docs/openapi.yaml -o docs/preview.html && start docs/preview.html"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.3.0",
    "@redocly/cli": "^2.20.4",
    "eslint": "^10.0.2",
    "globals": "^15.1.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.8",
    "http-errors": "^2.0.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0"
  }
}
