<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Reset your password</title>
  </head>
  <body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h2>Password Reset Request</h2>
    <p>Hi {{name}},</p>
    <p>Click the button below to reset your password. The link is valid for <strong>5 minutes</strong>.</p>
    <a
      href="{{resetLink}}"
      style="display: inline-block; padding: 12px 24px; background-color: #4f46e5; color: #fff; text-decoration: none; border-radius: 6px;"
    >
      Reset Password
    </a>
    <p style="margin-top: 16px;">Or copy this link into your browser:</p>
    <p style="word-break: break-all; color: #555;">{{resetLink}}</p>
    <p style="color: #888; font-size: 13px;">If you didn't request this, please ignore this email.</p>
  </body>
</html>
